# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Twitter OAuth 2.0 Credentials
# Required for native Twitter login and posting
TWITTER_CLIENT_ID="YOUR_TWITTER_CLIENT_ID"
TWITTER_CLIENT_SECRET="YOUR_TWITTER_CLIENT_SECRET"
SESSION_SECRET="YOUR_SESSION_SECRET"

# LinkedIn OAuth 2.0 Credentials
# Required for native LinkedIn login and posting
LINKEDIN_CLIENT_ID="YOUR_LINKEDIN_CLIENT_ID"
LINKEDIN_CLIENT_SECRET="YOUR_LINKEDIN_CLIENT_SECRET"

# Facebook & Instagram OAuth Credentials
# Required for native Facebook/Instagram login and posting
FACEBOOK_APP_ID="YOUR_FACEBOOK_APP_ID"
FACEBOOK_APP_SECRET="YOUR_FACEBOOK_APP_SECRET"

# TikTok OAuth Credentials
# Required for native TikTok login and posting
TIKTOK_CLIENT_KEY="YOUR_TIKTOK_CLIENT_KEY"
TIKTOK_CLIENT_SECRET="YOUR_TIKTOK_CLIENT_SECRET"

# YouTube (Google) OAuth Credentials
# Required for native YouTube login and posting
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# Pinterest OAuth Credentials
# Required for native Pinterest login and posting
PINTEREST_CLIENT_ID="YOUR_PINTEREST_CLIENT_ID"
PINTEREST_CLIENT_SECRET="YOUR_PINTEREST_CLIENT_SECRET"
